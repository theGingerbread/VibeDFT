&CONTROL
  calculation = '{{ qe.pw.control.calculation | default('vc-relax') }}'
  outdir = '{{ qe.pw.control.outdir | default('./out_rx/') }}'
  prefix = '{{ qe.pw.control.prefix }}'
  pseudo_dir = '{{ material.pseudo_dir }}'
  tprnfor = .{{ 'true' if qe.pw.control.tprnfor | default(true) else 'false' }}
  tstress = .{{ 'true' if qe.pw.control.tstress | default(true) else 'false' }}
  verbosity = '{{ qe.pw.control.verbosity | default('high') }}'
  etot_conv_thr = {{ qe.pw.control.etot_conv_thr | default('1.0d-6') }}
  forc_conv_thr = {{ qe.pw.control.forc_conv_thr | default('1.0d-4') }}
/

&SYSTEM
  ibrav = {{ qe.pw.system.ibrav | default(0) }}
  nat = {{ material.atomic_positions | length }}
  ntyp = {{ material.atomic_species | length }}
  ecutwfc = {{ qe.pw.system.ecutwfc }}
  ecutrho = {{ qe.pw.system.ecutrho }}
  occupations = '{{ qe.pw.system.occupations | default('smearing') }}'
  smearing = '{{ qe.pw.system.smearing | default('gaussian') }}'
  degauss = {{ qe.pw.system.degauss | default('3.7d-3') }}
{% if qe.pw.system.assume_isolated and qe.pw.system.assume_isolated != '' %}
  assume_isolated = '{{ qe.pw.system.assume_isolated }}'
{% endif %}
{% if qe.pw.system.cell_dofree and qe.pw.system.cell_dofree != '' %}
  cell_dofree = '{{ qe.pw.system.cell_dofree }}'
{% endif %}
{% if qe.pw.system.input_dft and qe.pw.system.input_dft != '' %}
  input_dft = '{{ qe.pw.system.input_dft }}'
{% endif %}
{% if qe.pw.system.tot_charge and qe.pw.system.tot_charge != 0 %}
  tot_charge = {{ qe.pw.system.tot_charge }}
{% endif %}
/

&ELECTRONS
  conv_thr = {{ qe.pw.electrons.conv_thr | default('1.0d-10') }}
  electron_maxstep = {{ qe.pw.electrons.electron_maxstep | default(200) }}
  mixing_beta = {{ qe.pw.electrons.mixing_beta | default('4.0d-1') }}
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
{% for el, spec in material.atomic_species.items() %}
{{ el }}  {{ spec.mass }}  {{ spec.pseudo }}
{%- endfor %}

CELL_PARAMETERS (angstrom)
{% for row in material.cell_parameters %}
  {{ "%14.9f"|format(row[0]) }} {{ "%14.9f"|format(row[1]) }} {{ "%14.9f"|format(row[2]) }}
{%- endfor %}

ATOMIC_POSITIONS (crystal)
{% for atom in material.atomic_positions %}
{{ atom.element }}  {{ "%20.10f"|format(atom.pos[0]) }} {{ "%20.10f"|format(atom.pos[1]) }} {{ "%20.10f"|format(atom.pos[2]) }}
{%- endfor %}

K_POINTS (automatic)
{{ common.kpoints.grid[0] }} {{ common.kpoints.grid[1] }} {{ common.kpoints.grid[2] }} 0 0 0
